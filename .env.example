# =============================================================================
# REQUIRED
# =============================================================================
TOKEN=<DISCORD BOT TOKEN>

POSTGRES_USER=<USER>
POSTGRES_PASSWORD=<PASSWORD>
POSTGRES_HOST=unorouter-bot-db
POSTGRES_DB=unorouter-bot-db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}

# Comma-separated guild ids to register slash commands instantly (leave empty for global)
GUILD_IDS=

# =============================================================================
# AI (optional)
# =============================================================================
# Comma-separated Google Gemini API keys (rotated on rate limit / key errors)
GOOGLE_GENERATIVE_AI_API_KEY=
# GIF search (https://partner.klipy.com/api-keys)
KLIPY_API_KEY=

# =============================================================================
# ROLES (exact Discord role names, comma separated)
# =============================================================================
STAFF_ROLES=          # e.g. Admin,Moderator
STATUS_ROLES=         # e.g. Verified,VoiceOnly,Jail
LEVEL_ROLES=          # e.g. Script Kiddie!,Copy Paster!,Vibe Coder!,Intern!,Junior Dev!,Mid Dev!,Senior Dev!,Lead Dev!,Tech Lead!

# =============================================================================

# =============================================================================
# TICKETS + BUG REPORTS (channel/category ids)
# =============================================================================
# Channels are matched by NAME (case-insensitive substring), not id, so emoji
# renames like "ticket-logs" -> "📄│ticket-logs" keep working. Use the stable slug.
# Hidden category where private per-ticket channels are created (deny @everyone view)
TICKET_CATEGORY=tickets
# Channel where ticket transcripts are posted on close
TICKET_LOG_CHANNEL=ticket-logs
# Forum channel watched for bug reports
BUG_REPORT_FORUM_CHANNEL=bug-bounty

# =============================================================================
# BALANCE GRANTS (new-api integration)
# =============================================================================
NEW_API_URL=https://api.unorouter.com
# Access token of a new-api admin user (Role >= 10), sent as Authorization: Bearer
NEW_API_ADMIN_TOKEN=
# new-api admin user id that owns the access token (system token = user 1)
NEW_API_USER_ID=1
# Channel where grant announcements are posted (optional)
GRANT_LOG_CHANNEL=grants-log
# Bonus when a member starts boosting, in DOLLARS (0 disables)
# new-api quota units per US dollar (default QuotaPerUnit)
QUOTA_PER_DOLLAR=500000
BOOST_GRANT_DOLLARS=1
# Channel where boost reward announcements are posted (optional)
BOOST_CHANNEL=boosters
# One-time bonus in DOLLARS when a user verifies their Discord link (0 = role only)
CONNECT_GRANT_DOLLARS=1
# Role given to users who linked Discord <-> unorouter
CONNECTED_ROLE=unorouter.com

# =============================================================================
# VOTE REWARDS (server listing-site webhooks)
# =============================================================================
# Inbound HTTP port for vote webhooks (Traefik routes bot.unorouter.com here)
WEBHOOK_PORT=4000
# Balance granted per vote, in DOLLARS (all sites; 0 disables rewards)
VOTE_GRANT_DOLLARS=0.10
# Secret set in each site's SERVER webhook dashboard; sent back as raw
# Authorization header. Leave blank to disable that site (its webhooks then 401).
# https://top.gg/servers/<guildId>/edit -> Webhooks
TOPGG_WEBHOOK_SECRET=
# https://discords.com server edit page -> Webhooks
DISCORDS_WEBHOOK_SECRET=

# =============================================================================
# BRANDING
# =============================================================================
BOT_NAME=unorouter
WEBSITE_URL=https://unorouter.com
BOT_ACTIVITY=unorouter.com

# =============================================================================
