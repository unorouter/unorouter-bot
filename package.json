{
  "name": "unorouter-bot",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "dotenvx run --env NODE_ENV=production -- node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "prettier": "prettier -w .",
    "openapi": "orval --config ./orval.config.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:introspect": "drizzle-kit introspect",
    "db:reset": "tsx drizzle/reset-db.ts && drizzle-kit generate"
  },
  "dependencies": {
    "@ai-sdk/google": "3.0.80",
    "@elysiajs/node": "^1.4.5",
    "@sinclair/typebox": "0.34.49",
    "ai": "6.0.197",
    "dayjs": "1.11.21",
    "discord.js": "14.26.4",
    "discordx": "11.13.3",
    "drizzle-orm": "0.45.2",
    "drizzle-typebox": "0.3.3",
    "elysia": "1.4.29",
    "lru-cache": "11.5.1",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.71.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.2",
    "drizzle-kit": "0.31.10",
    "orval": "8.15.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}